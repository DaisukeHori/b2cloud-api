{
  "name": "b2cloud-api",
  "version": "0.1.0",
  "description": "\u30e4\u30de\u30c8\u904b\u8f38 B2\u30af\u30e9\u30a6\u30c9 \u306e TypeScript API / MCP\u30b5\u30fc\u30d0\u30fc",
  "type": "commonjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "build": "echo skipping tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src api --ext .ts",
    "format": "prettier --write 'src/**/*.ts' 'api/**/*.ts'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:full": "B2_E2E_FULL=1 vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.0.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tough-cookie": "^5.0.0",
    "undici": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pako": "^2.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/node": "^5.7.7",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaisukeHori/b2cloud-api.git"
  },
  "keywords": [
    "yamato",
    "b2cloud",
    "\u9001\u308a\u72b6",
    "\u914d\u9001",
    "mcp",
    "typescript"
  ],
  "author": "DaisukeHori"
}