# ============================================================
# b2cloud-api 環境変数
# ============================================================

# ----- 必須 -----

# B2クラウドのログイン情報（ヤマトビジネスメンバーズ）
B2_CUSTOMER_CODE=
B2_CUSTOMER_PASSWORD=

# MCPサーバーのアクセスキー（b2mcp-xxxxx の形式推奨、自前で生成）
MCP_API_KEY=


# ----- 任意 -----

# お客様コード枝番（ほとんどのアカウントでは空のまま）
B2_CUSTOMER_CLS_CODE=

# 個人ユーザーID（個人ユーザー設定している場合のみ）
B2_LOGIN_USER_ID=

# デフォルト用紙タイプ
# m=A4マルチ / m5=A5マルチ(デフォルト推奨) / 0=発払い専用紙
# 4=タイム/ラベル発払い / 5=着払い/ラベルコレクト
# 7=ネコポス・ゆうパケット / 8=コンパクト/ラベルコンパクト
# A=ネコポス専用 / 3=DM・ゆうメール(8面付)
B2_DEFAULT_PRINT_TYPE=m5


# ----- デフォルト依頼主情報 -----
# （毎回の伝票作成時に shipper_* を省略可能にする）

B2_DEFAULT_SHIPPER_NAME=
B2_DEFAULT_SHIPPER_TEL=
B2_DEFAULT_SHIPPER_ZIP=
B2_DEFAULT_SHIPPER_ADDR1=
B2_DEFAULT_SHIPPER_ADDR2=
B2_DEFAULT_SHIPPER_ADDR3=


# ----- 請求先情報 -----
# （initdisplayから取得できない場合の手動指定）

# invoice_code = お客様コード10桁（通常はB2_CUSTOMER_CODEと同一）
B2_DEFAULT_INVOICE_CODE=

# invoice_code_ext = ほぼ常に空（★枝番を入れるとエラーになる）
B2_DEFAULT_INVOICE_CODE_EXT=

# invoice_freight_no = ★運賃管理番号（枝番）をここに入れる（例: "01"）
B2_DEFAULT_INVOICE_FREIGHT_NO=01
